  "keyFeatures": [
    "JWT-based authentication with secure user management",
    "Task organization with folders, tags, and subtasks",
    "Priority and status tracking for tasks",
    "PostgreSQL database with JPA/Hibernate ORM",
    "Docker containerization for easy deployment",
    "RESTful API design with comprehensive error handling",
    "CORS support for frontend integration",
    "Actuator health checks for monitoring"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "GET /api/auth/me",
    "POST /api/tasks",
    "GET /api/tasks",
    "GET /api/tasks/{taskId}",
    "PUT /api/tasks/{taskId}",
    "DELETE /api/tasks/{taskId}",
    "POST /api/folders",
    "GET /api/folders",
    "GET /api/folders/{folderId}",
    "PUT /api/folders/{folderId}",
    "DELETE /api/folders/{folderId}",
    "POST /api/tags",
    "GET /api/tags",
    "GET /api/tags/{tagId}",
    "PUT /api/tags/{tagId}",
    "DELETE /api/tags/{tagId}",
    "POST /api/subtasks",
    "GET /api/tasks/{taskId}/subtasks",
    "PUT /api/subtasks/{subtaskId}",
    "DELETE /api/subtasks/{subtaskId}",
    "GET /actuator/health"
  ]
